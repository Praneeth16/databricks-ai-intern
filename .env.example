# databricks-ai-intern — local dev environment.
# Copy to `.env` and fill in. Never commit `.env`.
#
# Auth precedence (Databricks SDK unified chain):
#   1. DATABRICKS_HOST + DATABRICKS_TOKEN (PAT)
#   2. `databricks auth login` profile (~/.databrickscfg)
#   3. DATABRICKS_CLIENT_ID + DATABRICKS_CLIENT_SECRET (M2M service principal)
#
# On Databricks Apps, everything below is injected by the runtime — no .env
# needed. The app.yaml `resources:` + `user_authorization:` sections scope
# access; OBO tokens arrive via X-Forwarded-Access-Token headers.

# --- Required (local dev) ---
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi...

# --- Required for UC SQL reads (uc_inspect_dataset, Lakeview queries) ---
DATABRICKS_WAREHOUSE_ID=

# --- UC namespace. Defaults match configs/main_agent_config.json. ---
DATABRICKS_AI_INTERN_UC_CATALOG=databricks_ai_intern
DATABRICKS_AI_INTERN_UC_SCHEMA=agent
DATABRICKS_AI_INTERN_UC_VOLUME=scratch

# --- MLflow experiment path (workspace-relative) ---
DATABRICKS_AI_INTERN_EXPERIMENT_PATH=/Shared/databricks-ai-intern

# --- Prompt Registry identifier (MLflow prompts API) ---
DATABRICKS_AI_INTERN_PROMPT_NAME=databricks_ai_intern.agent.system_prompt

# --- Lakebase + sandbox compute (optional until P6/P8 land) ---
DATABRICKS_AI_INTERN_LAKEBASE_INSTANCE=databricks-ai-intern-state
DATABRICKS_AI_INTERN_INSTANCE_POOL_ID=
DATABRICKS_AI_INTERN_NODE_TYPE=g5.xlarge
DATABRICKS_AI_INTERN_RUNTIME=15.4.x-gpu-ml-scala2.12

# --- Secret scope holding user GitHub tokens, optional external-model keys ---
DATABRICKS_AI_INTERN_SECRET_SCOPE=databricks-ai-intern

# --- GitHub research tool (kept from upstream). PAT with repo read scope. ---
GITHUB_TOKEN=

# --- Optional: HF research corpus access. Kept orthogonal to infra. ---
HF_TOKEN=
